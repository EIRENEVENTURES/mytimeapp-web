# Database
DATABASE_URL=postgresql://username:password@localhost:5432/mytimeapp

# JWT Secret (change this in production!)
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Paystack Configuration
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here
VITE_PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
VITE_PAYSTACK_WEBHOOK_SECRET=whsec_your_paystack_webhook_secret_here
VITE_BACKEND_API_URL=https://mytimeapp-n8zd.onrender.com
VITE_APP_DEEP_LINK=mytimeapp://payment/callback

# File Storage
USE_BLOB_STORAGE=true
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Email (Resend)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@mytimeapp.net

# Redis (for production scaling)
REDIS_URL=redis://localhost:6379

# Stream Chat Configuration
STREAM_CHAT_API_KEY=your_stream_chat_api_key_here
STREAM_CHAT_API_SECRET=your_stream_chat_api_secret_here

# Stream Video Configuration
STREAM_VIDEO_API_KEY=your_stream_video_api_key_here
STREAM_VIDEO_API_SECRET=your_stream_video_api_secret_here

# WebRTC Configuration
EXPO_PUBLIC_WEBRTC_SIGNALING_URL=wss://your-domain.com:3001

# TURN Server Configuration (for production NAT traversal)
WEBRTC_TURN_SERVERS=turn:your-turn-server.com:3478?transport=udp
WEBRTC_TURN_USERNAME=your-turn-username
WEBRTC_TURN_CREDENTIALS=your-turn-password

# Signaling Server Configuration
WEBRTC_SIGNALING_PORT=3001
WEBRTC_CORS_ORIGIN=https://your-domain.com
HTTPS_ENABLED=true

# SSL Certificate Paths (for HTTPS)
# Place these in backend/ssl/ directory
# SSL_KEY_PATH=./ssl/private.key
# SSL_CERT_PATH=./ssl/certificate.crt
